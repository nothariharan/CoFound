# Production only — URL of the deployed backend (no trailing slash).
# Leave empty for local dev (Vite proxies /api to localhost:8000).
# On Vercel, set this to your Render URL, e.g.:
# VITE_API_BASE_URL=https://cofound-tshh.onrender.com
# If unset in production builds, the app falls back to that Render host.
VITE_API_BASE_URL=
