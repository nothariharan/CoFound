# MongoDB Atlas — CoFound cluster
MONGODB_URI=mongodb+srv://user:pass@cofound.ivajiy8.mongodb.net/cofounder?appName=CoFound
MONGODB_DB=cofounder
# Same URI for MongoDB MCP server — required for agent runtime (mongodb-mcp-server via npx)
MDB_MCP_CONNECTION_STRING=mongodb+srv://user:pass@cofound.ivajiy8.mongodb.net/cofounder?appName=CoFound
# Route agent persistence through mongodb-mcp-server at runtime
USE_MONGODB_MCP=true

# Google Cloud / Gemini — required for real agent intelligence (get key at https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.0-flash
GOOGLE_CLOUD_PROJECT=cofound-agent
# VERTEX_AGENT_ENGINE_ENABLED=false  # requires GCP billing; ADK runs via API key by default

# Research Tools
FIRECRAWL_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Integrations
GITHUB_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=

# Voice (Deepgram STT/TTS — server-side proxy)
DEEPGRAM_API_KEY=

# Optional orchestrator remote LLM (host dashboard only — never commit values)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
ORCHESTRATOR_MODEL_ID=amazon.nova-lite-v1:0

# App — add your production frontend origin(s), comma-separated
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BACKEND_PORT=8000
